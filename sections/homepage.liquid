<section class="site-wrapper" id="top">
  <header class="site-header">
    <div class="container">
      <a class="brand" href="#top">
        <img src="{{ 'eelib-logo.svg' | asset_url }}" alt="{{ section.settings.brand_logo_alt | escape }}">
        <div class="brand-copy">
          <span class="brand-domain">{{ section.settings.brand_domain }}</span>
          <span class="brand-company">{{ section.settings.brand_company }}</span>
        </div>
      </a>
      <nav class="main-nav" aria-label="主导航">
        <a href="#ebooks">{{ section.settings.nav_ebooks_label }}</a>
        <a href="#modules">{{ section.settings.nav_modules_label }}</a>
        <a href="#magazine">{{ section.settings.nav_magazine_label }}</a>
        <a href="#learning">{{ section.settings.nav_learning_label }}</a>
        <a class="cta" href="#contact">{{ section.settings.nav_contact_label }}</a>
      </nav>
      <div class="header-actions">
        <button class="cart-toggle" type="button" data-cart-toggle aria-label="打开购物车" aria-controls="cart-panel" aria-expanded="false">
          <span>{{ section.settings.cart_label }}</span>
          <span class="cart-count" data-cart-count>0</span>
        </button>
      </div>
      <button class="nav-toggle" aria-label="展开导航" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <aside class="cart-panel" id="cart-panel" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cart-heading">
    <div class="cart-header">
      <h2 id="cart-heading">{{ section.settings.cart_heading }}</h2>
      <button type="button" class="cart-close" data-cart-close aria-label="关闭购物车">×</button>
    </div>
    <div class="cart-body">
      <p class="cart-empty" data-cart-empty>{{ section.settings.cart_empty }}</p>
      <ul class="cart-items" data-cart-items></ul>
    </div>
    <div class="cart-footer">
      <div class="cart-total">{{ section.settings.cart_total_label }} <span data-cart-total>¥0</span></div>
      <button class="btn primary" type="button" data-checkout>{{ section.settings.checkout_label }}</button>
    </div>
  </aside>
  <div class="cart-backdrop" data-cart-backdrop hidden></div>

  <main>
    <section class="hero">
      <div class="container hero-layout">
        <div class="hero-copy">
          <p class="eyebrow">{{ section.settings.hero_eyebrow }}</p>
          <h1>{{ section.settings.hero_heading }}</h1>
          <p class="lead">{{ section.settings.hero_subheading }}</p>
          <div class="hero-actions">
            <a class="btn primary" href="{{ section.settings.hero_primary_link }}">{{ section.settings.hero_primary_label }}</a>
            <a class="btn ghost" href="{{ section.settings.hero_secondary_link }}">{{ section.settings.hero_secondary_label }}</a>
          </div>
          {% assign hero_metrics = section.blocks | where: 'type', 'hero_metric' %}
          {% if hero_metrics.size > 0 %}
            <dl class="hero-metrics">
              {% for block in hero_metrics %}
                <div>
                  <dt>{{ block.settings.metric_value }}</dt>
                  <dd>{{ block.settings.metric_label }}</dd>
                </div>
              {% endfor %}
            </dl>
          {% endif %}
        </div>
        <div class="hero-showcase" aria-hidden="true">
          {% assign hero_cards = section.blocks | where: 'type', 'hero_card' %}
          {% for block in hero_cards %}
            <article class="showcase-card">
              {% if block.settings.badge != blank %}
                <p class="badge">{{ block.settings.badge }}</p>
              {% endif %}
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
              {% if block.settings.link_label != blank %}
                <a href="{{ block.settings.link_url }}" class="link">{{ block.settings.link_label }}</a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="collections">
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">{{ section.settings.collections_eyebrow }}</p>
          <h2>{{ section.settings.collections_heading }}</h2>
          <p>{{ section.settings.collections_description }}</p>
        </header>
        {% assign collection_cards = section.blocks | where: 'type', 'collection_card' %}
        {% if collection_cards.size > 0 %}
          <div class="collection-grid">
            {% for block in collection_cards %}
              <article class="collection-card">
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.description }}</p>
                {% if block.settings.link_label != blank %}
                  <a class="link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </section>

    <section class="spotlight">
      <div class="container spotlight-layout">
        <div class="spotlight-copy">
          <p class="eyebrow">{{ section.settings.spotlight_eyebrow }}</p>
          <h2>{{ section.settings.spotlight_heading }}</h2>
          <p>{{ section.settings.spotlight_description }}</p>
          {% assign spotlight_items = section.blocks | where: 'type', 'spotlight_item' %}
          {% if spotlight_items.size > 0 %}
            <ul class="spotlight-list">
              {% for block in spotlight_items %}
                <li>{{ block.settings.text }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          <div class="spotlight-actions">
            <a class="btn primary" href="{{ section.settings.spotlight_primary_link }}">{{ section.settings.spotlight_primary_label }}</a>
            <a class="btn ghost" href="{{ section.settings.spotlight_secondary_link }}">{{ section.settings.spotlight_secondary_label }}</a>
          </div>
        </div>
        <div class="spotlight-cover" aria-hidden="true">
          <span>{{ section.settings.spotlight_badge }}</span>
        </div>
      </div>
    </section>

    <section class="ebook-market" id="ebooks">
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">{{ section.settings.ebooks_eyebrow }}</p>
          <h2>{{ section.settings.ebooks_heading }}</h2>
          <p>{{ section.settings.ebooks_description }}</p>
        </header>
        <div class="product-toolbar" role="search">
          <label class="search-field">
            <span class="sr-only">{{ section.settings.ebooks_search_label }}</span>
            <input type="search" placeholder="{{ section.settings.ebooks_search_placeholder }}" data-product-search />
          </label>
          <div class="filter-chips" role="group" aria-label="{{ section.settings.ebooks_filter_label }}">
            {% assign filter_chips = section.blocks | where: 'type', 'filter_chip' %}
            {% for block in filter_chips %}
              <button type="button" class="chip{% if forloop.first %} active{% endif %}" data-filter="{{ block.settings.filter_value }}">{{ block.settings.label }}</button>
            {% endfor %}
          </div>
        </div>
        <div class="product-grid">
          {% assign ebook_cards = section.blocks | where: 'type', 'ebook' %}
          {% for block in ebook_cards %}
            {% assign product = block.settings.product %}
            {% assign product_title = block.settings.fallback_title %}
            {% assign product_description = block.settings.fallback_description %}
            {% assign product_price = block.settings.fallback_price %}
            {% assign product_tags = block.settings.tags %}
            {% assign product_type = block.settings.product_type %}
            {% assign product_link = block.settings.link_url %}
            {% assign data_price = block.settings.fallback_price | remove: '¥' | remove: '￥' | remove: ',' %}
            {% assign featured_image = '' %}
            {% if product %}
              {% assign product_title = product.title %}
              {% assign product_description = product.description | strip_html | truncate: 120 %}
              {% assign product_price = product.price | money_without_trailing_zeros %}
              {% assign data_price = product.price | divided_by: 100.0 %}
              {% assign product_type = product.product_type | default: block.settings.product_type %}
              {% assign product_link = product.url %}
              {% if product.featured_image %}
                {% assign featured_image = product.featured_image | image_url: width: 480 %}
              {% endif %}
            {% endif %}
            {% if featured_image == '' and block.settings.fallback_image != blank %}
              {% assign featured_image = block.settings.fallback_image | asset_url %}
            {% endif %}
            <article class="product-card" data-product-card data-tags="{{ product_tags }}" data-title="{{ product_title | escape }}">
              {% if block.settings.badge != blank %}
                <span class="badge">{{ block.settings.badge }}</span>
              {% endif %}
              {% if featured_image != '' %}
                <img src="{{ featured_image }}" alt="{{ product_title | escape }}" loading="lazy">
              {% endif %}
              <h3>{{ product_title }}</h3>
              <p>{{ product_description }}</p>
              <div class="price">{{ product_price }}</div>
              <button class="btn secondary" type="button" data-add-to-cart data-product="{{ product_title }}" data-price="{{ data_price }}" data-type="{{ product_type }}">{{ section.settings.add_to_cart_label }}</button>
              {% if product_link != blank %}
                <a class="link" href="{{ product_link }}">{{ block.settings.link_label }}</a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="modules" id="modules">
      <div class="container">
        <header class="section-header">
          <p class="eyebrow">{{ section.settings.modules_eyebrow }}</p>
          <h2>{{ section.settings.modules_heading }}</h2>
          <p>{{ section.settings.modules_description }}</p>
        </header>
        <div class="module-grid">
          {% assign module_cards = section.blocks | where: 'type', 'module' %}
          {% for block in module_cards %}
            {% assign product = block.settings.product %}
            {% assign product_title = block.settings.fallback_title %}
            {% assign product_description = block.settings.fallback_description %}
            {% assign product_price = block.settings.fallback_price %}
            {% assign data_price = block.settings.fallback_price | remove: '¥' | remove: '￥' | remove: ',' %}
            {% assign product_type = block.settings.product_type %}
            {% if product %}
              {% assign product_title = product.title %}
              {% assign product_description = product.description | strip_html | truncate: 120 %}
              {% assign product_price = product.price | money_without_trailing_zeros %}
              {% assign data_price = product.price | divided_by: 100.0 %}
              {% assign product_type = product.product_type | default: block.settings.product_type %}
            {% endif %}
            <article class="module-card">
              <h3>{{ product_title }}</h3>
              <p>{{ product_description }}</p>
              <div class="price">{{ product_price }}</div>
              <button class="btn secondary" type="button" data-add-to-cart data-product="{{ product_title }}" data-price="{{ data_price }}" data-type="{{ product_type }}">{{ section.settings.add_to_cart_label }}</button>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="magazine" id="magazine">
      <div class="container magazine-layout">
        <div class="magazine-copy">
          <p class="eyebrow">{{ section.settings.magazine_eyebrow }}</p>
          <h2>{{ section.settings.magazine_heading }}</h2>
          <p>{{ section.settings.magazine_description }}</p>
          <ul>
            {% assign magazine_bullets = section.blocks | where: 'type', 'magazine_bullet' %}
            {% for block in magazine_bullets %}
              <li>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>
        </div>
        <form class="magazine-form" aria-label="{{ section.settings.magazine_form_label }}">
          <label class="sr-only" for="magazine-email">{{ section.settings.magazine_email_label }}</label>
          <input id="magazine-email" type="email" placeholder="{{ section.settings.magazine_email_placeholder }}" required />
          <button class="btn primary" type="submit">{{ section.settings.magazine_submit_label }}</button>
          <p class="form-helper">{{ section.settings.magazine_helper }}</p>
        </form>
      </div>
    </section>

    <section class="learning" id="learning">
      <div class="container learning-layout">
        <div>
          <header class="section-header">
            <p class="eyebrow">{{ section.settings.learning_eyebrow }}</p>
            <h2>{{ section.settings.learning_heading }}</h2>
            <p>{{ section.settings.learning_description }}</p>
          </header>
          <div class="path-list">
            {% assign learning_paths = section.blocks | where: 'type', 'learning_path' %}
            {% for block in learning_paths %}
              <article>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.description }}</p>
              </article>
            {% endfor %}
          </div>
        </div>
        <aside class="learning-aside">
          <h3>{{ section.settings.learning_aside_heading }}</h3>
          <ul>
            {% assign learning_resources = section.blocks | where: 'type', 'learning_resource' %}
            {% for block in learning_resources %}
              <li>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>
          <a class="btn ghost" href="{{ section.settings.learning_cta_link }}">{{ section.settings.learning_cta_label }}</a>
        </aside>
      </div>
    </section>

    <section class="testimonials">
      <div class="container testimonials-grid">
        {% assign testimonials = section.blocks | where: 'type', 'testimonial' %}
        {% for block in testimonials %}
          <article>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.quote }}</p>
          </article>
        {% endfor %}
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="container contact-layout">
        <div class="contact-copy">
          <p class="eyebrow">{{ section.settings.contact_eyebrow }}</p>
          <h2>{{ section.settings.contact_heading }}</h2>
          <p>{{ section.settings.contact_description }}</p>
          <ul>
            {% assign contact_points = section.blocks | where: 'type', 'contact_point' %}
            {% for block in contact_points %}
              <li>{{ block.settings.text }}</li>
            {% endfor %}
          </ul>
        </div>
        <form class="contact-form" aria-label="{{ section.settings.contact_form_label }}">
          <label for="name">{{ section.settings.contact_name_label }}</label>
          <input id="name" name="name" type="text" placeholder="{{ section.settings.contact_name_placeholder }}" required />
          <label for="email">{{ section.settings.contact_email_label }}</label>
          <input id="email" name="email" type="email" placeholder="{{ section.settings.contact_email_placeholder }}" required />
          <label for="message">{{ section.settings.contact_message_label }}</label>
          <textarea id="message" name="message" rows="4" placeholder="{{ section.settings.contact_message_placeholder }}"></textarea>
          <button class="btn primary" type="submit">{{ section.settings.contact_submit_label }}</button>
        </form>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-layout">
      <div>
        <a class="brand" href="#top">
          <img src="{{ 'eelib-logo.svg' | asset_url }}" alt="{{ section.settings.brand_logo_alt | escape }}">
          <div class="brand-copy">
            <span class="brand-domain">{{ section.settings.brand_domain }}</span>
            <span class="brand-company">{{ section.settings.brand_company }}</span>
          </div>
        </a>
        <p>© <span id="year"></span> {{ section.settings.brand_company }}. {{ section.settings.footer_copy }}</p>
      </div>
      <div class="footer-links">
        <div>
          <h3>{{ section.settings.footer_product_heading }}</h3>
          <a href="#ebooks">{{ section.settings.nav_ebooks_label }}</a>
          <a href="#modules">{{ section.settings.nav_modules_label }}</a>
          <a href="#magazine">{{ section.settings.nav_magazine_label }}</a>
        </div>
        <div>
          <h3>{{ section.settings.footer_resource_heading }}</h3>
          <a href="#learning">{{ section.settings.nav_learning_label }}</a>
          <a href="#contact">{{ section.settings.nav_contact_label }}</a>
          <a href="{{ section.settings.footer_download_link }}">{{ section.settings.footer_download_label }}</a>
        </div>
        <div>
          <h3>{{ section.settings.footer_support_heading }}</h3>
          <a href="#contact">{{ section.settings.footer_support_contact }}</a>
          <a href="{{ section.settings.footer_privacy_link }}">{{ section.settings.footer_privacy_label }}</a>
          <a href="{{ section.settings.footer_terms_link }}">{{ section.settings.footer_terms_label }}</a>
        </div>
      </div>
    </div>
  </footer>
</section>

